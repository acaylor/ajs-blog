---
// Trailing shell prompt that cycles through a few fake commands — types one
// out character by character, "executes" it (prints an output line and a
// fresh prompt below, like a real shell), holds, deletes, then types the
// next. Outputs use real build/site data where they can. Disabled under
// prefers-reduced-motion (first command + output shown statically).

import { getBlogStats } from '../utils/blog-stats';
import { commitSha, buildYmd } from '../utils/build-info';

const { postCount, uptimeDays, firstPostYmd } = await getBlogStats();

const messages = [
  {
    cmd: 'echo "Comments were removed, email instead"',
    out: 'Comments were removed, email instead',
  },
  { cmd: 'uptime', out: `up ${uptimeDays} days,  1 user,  load average: 0.42, 0.15, 0.09` },
  { cmd: 'ls src/content/blog | wc -l', out: `${postCount}` },
  {
    cmd: 'journalctl -u aj-blog.service',
    out: `-- Logs begin at ${firstPostYmd}, end at ${buildYmd}. --`,
  },
  {
    cmd: 'cat src/content/blog/index.html',
    out: 'cat: src/content/blog/index.html: No such file or directory',
  },
  {
    cmd: 'claude -p "Write me a new post and make it good"',
    out: 'declined: a human still writes these',
  },
  { cmd: 'git commit -m "Add new post"', out: `[main ${commitSha}] Add new post` },
  {
    cmd: 'systemctl status aj-blog.service',
    out: `● aj-blog.service — active (running) since ${firstPostYmd}; ${uptimeDays} days ago`,
  },
  { cmd: 'whoami', out: 'aj' },
  { cmd: 'man dmesg', out: 'you are reading it' },
  { cmd: 'echo "I ran out of coffee again"', out: 'I ran out of coffee again' },
  { cmd: 'shutdown -r now', out: 'Connection to blog closed.' },
];
---

<div class="prompt">
  <span class="line">
    <span class="ps1" aria-hidden="true">aj@blog:~$ </span><span class="cmd" aria-hidden="true"
    ></span><span class="cursor" aria-hidden="true"></span>
  </span>
  <span class="out" aria-hidden="true" hidden></span>
  <span class="line line2" aria-hidden="true" hidden>
    <span class="ps1">aj@blog:~$ </span><span class="cursor"></span>
  </span>
</div>

<script is:inline define:vars={{ messages }}>
  function initPrompt() {
    document.querySelectorAll('.prompt:not([data-prompt-attached])').forEach((root) => {
      root.setAttribute('data-prompt-attached', '');
      const cmd = root.querySelector('.cmd');
      const out = root.querySelector('.out');
      const line2 = root.querySelector('.line2');
      const cursor1 = root.querySelector('.line .cursor');
      if (!cmd || !out || !line2 || !cursor1) return;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        // No animation: show the first command and its output statically.
        cmd.textContent = messages[0].cmd;
        out.textContent = messages[0].out;
        out.hidden = false;
        line2.hidden = false;
        cursor1.style.display = 'none';
        return;
      }

      let mi = 0;
      let ci = 0;
      let typing = true;

      function tick() {
        const msg = messages[mi];
        if (typing) {
          ci += 1;
          cmd.textContent = msg.cmd.slice(0, ci);
          if (ci >= msg.cmd.length) {
            typing = false;
            // brief pause, then "execute": output + a fresh prompt line
            setTimeout(() => {
              out.textContent = msg.out;
              out.hidden = false;
              line2.hidden = false;
              cursor1.style.display = 'none';
              setTimeout(tick, 2600);
            }, 350);
            return;
          }
          // 55–115 ms per char gives a believable typing cadence
          setTimeout(tick, 55 + Math.random() * 60);
        } else {
          if (!out.hidden) {
            // clear the "screen" below before deleting the command
            out.hidden = true;
            line2.hidden = true;
            cursor1.style.display = '';
          }
          ci -= 1;
          cmd.textContent = msg.cmd.slice(0, ci);
          if (ci <= 0) {
            typing = true;
            mi = (mi + 1) % messages.length;
            setTimeout(tick, 500);
            return;
          }
          // delete a little faster than typing
          setTimeout(tick, 30 + Math.random() * 25);
        }
      }
      tick();
    });
  }

  initPrompt();
  document.addEventListener('astro:after-swap', initPrompt);
</script>
