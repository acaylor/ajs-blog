---
// Wraps every <pre> in a <div class="code-block"> and attaches a small
// bordered "copy" chip to the wrapper. The wrapper carries the relative
// positioning context so the button stays pinned to the visible corner
// while content inside the <pre> scrolls horizontally.
---

<script>
  function initCopyButtons(): void {
    document.querySelectorAll<HTMLPreElement>('pre:not([data-copy-attached])').forEach((pre) => {
      pre.setAttribute('data-copy-attached', '');

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block';
      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'copy-btn';
      btn.textContent = 'copy';
      btn.setAttribute('aria-label', 'Copy code to clipboard');
      wrapper.appendChild(btn);

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code.textContent ?? '');
          btn.textContent = 'copied';
          setTimeout(() => {
            btn.textContent = 'copy';
          }, 1500);
        } catch {
          /* clipboard refused — leave the label alone */
        }
      });
    });
  }

  initCopyButtons();
  document.addEventListener('astro:after-swap', initCopyButtons);
</script>

<style is:global>
  /* The wrapper carries position: relative so the copy chip is pinned to
     the visible corner; the <pre> inside it owns the horizontal scroll.
     We move the pre's vertical margin onto the wrapper so spacing in
     long-form prose is preserved. */
  .code-block {
    position: relative;
    margin: 1.25rem 0 1.5rem;
  }
  .code-block > pre {
    margin: 0;
  }

  .code-block .copy-btn {
    position: absolute;
    top: 0.4rem;
    right: 0.4rem;
    font: inherit;
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1rem 0.5rem;
    background: var(--bg);
    border: 1px solid var(--rule);
    color: var(--fg-faint);
    cursor: pointer;
    opacity: 0;
    transition:
      opacity 120ms,
      color 120ms,
      border-color 120ms;
  }

  .code-block:hover .copy-btn,
  .code-block:focus-within .copy-btn {
    opacity: 1;
  }

  .code-block .copy-btn:hover,
  .code-block .copy-btn:focus-visible {
    color: var(--amber);
    border-color: var(--amber);
  }

  @media (hover: none) {
    .code-block .copy-btn {
      opacity: 1;
    }
  }
</style>
