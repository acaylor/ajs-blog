---
interface Props {
  title: string;
  url?: string;
}

const { title, url } = Astro.props;
---

<nav class="share" data-title={title} data-url={url ?? ''} aria-label="Share">
  <a
    href="#"
    target="_blank"
    rel="noopener noreferrer"
    data-share="x"
    aria-label="Share on X (Twitter)"
  >
    <span class="arg">--x</span>
  </a>
  <a
    href="#"
    target="_blank"
    rel="noopener noreferrer"
    data-share="linkedin"
    aria-label="Share on LinkedIn"
  >
    <span class="arg">--linkedin</span>
  </a>
  <a
    href="#"
    target="_blank"
    rel="noopener noreferrer"
    data-share="hackernews"
    aria-label="Share on Hacker News"
  >
    <span class="arg">--hackernews</span>
  </a>
  <a href="#" data-share="copy" aria-label="Copy link to clipboard">
    <span class="arg">--copy-link</span>
  </a>
</nav>

<script>
  document.querySelectorAll<HTMLElement>('.share').forEach((share) => {
    const title = share.dataset.title ?? '';
    const pageUrl = share.dataset.url || window.location.href;

    share
      .querySelector<HTMLAnchorElement>('[data-share="x"]')
      ?.setAttribute(
        'href',
        `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(pageUrl)}`,
      );

    share
      .querySelector<HTMLAnchorElement>('[data-share="linkedin"]')
      ?.setAttribute(
        'href',
        `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`,
      );

    share
      .querySelector<HTMLAnchorElement>('[data-share="hackernews"]')
      ?.setAttribute(
        'href',
        `https://news.ycombinator.com/submitlink?u=${encodeURIComponent(pageUrl)}&t=${encodeURIComponent(title)}`,
      );

    const copyLink = share.querySelector<HTMLAnchorElement>('[data-share="copy"]');
    copyLink?.addEventListener('click', async (event) => {
      event.preventDefault();
      try {
        await navigator.clipboard.writeText(pageUrl);
        const arg = copyLink.querySelector<HTMLElement>('.arg');
        if (!arg) return;
        const original = arg.textContent ?? '--copy-link';
        arg.textContent = '--copied';
        setTimeout(() => {
          arg.textContent = original;
        }, 1500);
      } catch {
        /* clipboard refused — leave the label alone */
      }
    });
  });
</script>
