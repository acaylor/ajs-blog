---
import { buildVersion, commitSha } from '../utils/build-info';
import { resetClock, nextTs } from '../utils/log-clock';

interface Props {
  /** Override the `command line: cat /<route>` default. */
  command?: string;
  /** Optional `[ OK ]` (or other status) line shown beneath the command. */
  status?: {
    tag?: 'ok' | 'info' | 'warn' | 'note' | 'err';
    label?: string;
    text: string;
  };
  /** Hide the version preamble (used on /404 where it'd feel ironic, not playful). */
  showPreamble?: boolean;
}

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const { command = `cat ${path}`, status, showPreamble = true } = Astro.props;

const tagClass = status?.tag ? `tag-${status.tag}` : 'tag-ok';
const tagLabel = status?.label ?? '[ OK ]';

// The banner is the first log element on every page, so it owns starting
// the page's fake dmesg clock. Modules further down keep ticking it.
resetClock(Astro.url.pathname);
const tsPreamble = showPreamble ? nextTs(Astro.url.pathname) : null;
const tsCommand = nextTs(Astro.url.pathname);
const tsStatus = status ? nextTs(Astro.url.pathname) : null;
---

<div class="banner">
  {
    showPreamble && (
      <div class="row">
        <span class="ts" aria-hidden="true">
          {tsPreamble}
        </span>
        <span>
          <b>aj's blog</b> v{buildVersion} ({commitSha}) astro/6 &middot; gitlab-ci
        </span>
      </div>
    )
  }
  <div class="row">
    <span class="ts" aria-hidden="true">{tsCommand}</span>
    <span>command line: <b>{command}</b></span>
  </div>
  {
    status && (
      <div class="row">
        <span class="ts" aria-hidden="true">
          {tsStatus}
        </span>
        <span>
          <span class={tagClass}>{tagLabel}</span> {status.text}
        </span>
      </div>
    )
  }
</div>
