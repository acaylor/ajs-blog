---
interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  readingTime: string;
  href: string;
  image?: string;
  categories?: string[];
  draft?: boolean;
}

const {
  title,
  date,
  description,
  tags = [],
  readingTime,
  href,
  categories = [],
  draft = false,
} = Astro.props;

const isoDate = date.toISOString();
const ymd = isoDate.slice(0, 10);
const metaCategory = categories.slice(0, 2).join(' / ');
---

<div class="unit">
  <div class="head">
    <span class="dot" class:list={[{ draft }]} aria-hidden="true">●</span>
    <span class="name"><a href={href}>{title}</a></span>
  </div>
  <div class="meta">
    <time datetime={isoDate}>{ymd}</time> &middot; {readingTime}{
      metaCategory && <> &middot; {metaCategory}</>
    }
  </div>
  {description && <div class="desc">{description}</div>}
  {
    tags.length > 0 && (
      <div class="tags">
        <span class="label">tags</span>
        {tags.slice(0, 4).map((tag) => (
          <a href={`/tags/${tag}`} class="tag-link">
            {tag}
          </a>
        ))}
      </div>
    )
  }
</div>
