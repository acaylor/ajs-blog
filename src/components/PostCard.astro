---
interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  readingTime: string;
  href: string;
  image?: string;
}

const { title, date, description, tags = [], readingTime, href, image } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={href} class={`card ${image ? 'has-image' : ''}`}>
  <article>
    {image && <img src={image} alt="" class="card-image" loading="lazy" />}
    <div class="meta">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span class="dot">&middot;</span>
      <span>{readingTime}</span>
    </div>
    <h3>{title}</h3>
    {description && <p class="description">{description}</p>}
    {
      tags.length > 0 && (
        <div class="tags">
          {tags.slice(0, 3).map((tag) => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      )
    }
  </article>
</a>

<style>
  .card {
    display: block;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition:
      box-shadow var(--transition),
      transform var(--transition),
      border-color var(--transition);
    color: var(--color-text);
    height: 100%;
  }

  .card.has-image {
    padding: 0;
    overflow: hidden;
  }

  .card.has-image article {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .card-image {
    width: 100%;
    height: 10rem;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .card:hover {
    text-decoration: none;
    border-color: var(--color-border);
    box-shadow: 0 4px 12px var(--color-card-shadow-hover);
    transform: translateY(-2px);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    margin-bottom: 0.5rem;
  }

  .dot {
    color: var(--color-border);
  }

  h3 {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .description {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
</style>
