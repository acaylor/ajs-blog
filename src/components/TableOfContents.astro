---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const visible = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
---

{
  visible.length > 0 && (
    <aside class="toc" aria-label="Table of contents">
      <div class="toc-title">post.md</div>
      <ul>
        {visible.map((heading, i) => {
          const isLast = i === visible.length - 1;
          const glyph = isLast ? '└─ ' : '├─ ';
          return (
            <li class={`depth-${heading.depth}`}>
              <span class="tree" aria-hidden="true">
                {glyph}
              </span>
              <a href={`#${heading.slug}`}>{heading.text.toLowerCase()}</a>
            </li>
          );
        })}
      </ul>
    </aside>
  )
}
