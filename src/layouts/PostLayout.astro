---
import BaseLayout from './BaseLayout.astro';
import Banner from '../components/Banner.astro';
import Module from '../components/Module.astro';
import Prompt from '../components/Prompt.astro';
import ShareButtons from '../components/ShareButtons.astro';
import TableOfContents from '../components/TableOfContents.astro';
import CopyCode from '../components/CopyCode.astro';

interface AdjacentPost {
  title: string;
  href: string;
}

interface Props {
  title: string;
  date: Date;
  description?: string;
  author?: string;
  tags?: string[];
  categories?: string[];
  readingTime: string;
  wordCount?: number;
  image?: string;
  headings: { depth: number; slug: string; text: string }[];
  updated?: Date;
  postId: string;
  prev?: AdjacentPost;
  next?: AdjacentPost;
}

const {
  title,
  date,
  description,
  author,
  tags = [],
  categories = [],
  readingTime,
  wordCount,
  image,
  headings,
  updated,
  postId,
  prev,
  next,
} = Astro.props;

const isoDate = date.toISOString();
const ymd = isoDate.slice(0, 10);
const updatedYmd = updated?.toISOString().slice(0, 10);

const wordsText = wordCount
  ? `${wordCount >= 1000 ? `${(wordCount / 1000).toFixed(1)}k` : wordCount} words`
  : null;

const bannerStatus = {
  tag: 'ok' as const,
  label: '[ OK ]',
  text: [wordsText, readingTime, ymd].filter(Boolean).join(' · '),
};

const pageUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://blog.ayjc.net').toString();
---

<BaseLayout title={title} description={description} mainClass="post">
  <article>
    <Banner command={`cat /posts/${postId}.md`} status={bannerStatus} />

    <div class="post-meta">
      <time datetime={isoDate}>{ymd}</time>
      <span class="dot" aria-hidden="true">&middot;</span>
      <span>{readingTime}</span>
      {
        author && (
          <>
            <span class="dot" aria-hidden="true">
              &middot;
            </span>
            <span>by {author}</span>
          </>
        )
      }
      {
        categories.length > 0 && (
          <>
            <span class="dot" aria-hidden="true">
              &middot;
            </span>
            <span>
              {categories.map((cat, i) => (
                <>
                  {i > 0 && ' / '}
                  <a href={`/categories/${cat}/`} class="cat">
                    {cat}
                  </a>
                </>
              ))}
            </span>
          </>
        )
      }
      {
        updatedYmd && (
          <>
            <span class="dot" aria-hidden="true">
              &middot;
            </span>
            <span>updated {updatedYmd}</span>
          </>
        )
      }
    </div>

    <h1 class="post-title">{title}</h1>

    {
      tags.length > 0 && (
        <div class="post-tags-row">
          <span class="label">tags</span>
          {tags.map((tag) => (
            <a href={`/tags/${tag}/`} class="tag-link">
              {tag}
            </a>
          ))}
        </div>
      )
    }

    {
      image && (
        <figure class="figure hero">
          <img src={image} alt="" loading="lazy" />
        </figure>
      )
    }

    <Module name="body" />

    <div class="prose">
      <slot />
    </div>

    <Module name="share" />
    <ShareButtons title={title} url={pageUrl} />

    {
      (prev || next) && (
        <nav class="navnext" aria-label="Adjacent posts">
          {prev ? (
            <a href={prev.href}>
              <span class="dir" aria-hidden="true">
                &larr; prev
              </span>
              {prev.title}
            </a>
          ) : (
            <span />
          )}
          {next ? (
            <a href={next.href} class="next">
              <span class="dir" aria-hidden="true">
                next &rarr;
              </span>
              {next.title}
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }

    <Prompt />
  </article>

  <TableOfContents headings={headings} />
  <CopyCode />
</BaseLayout>
