---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ShareButtons from '../components/ShareButtons.astro';
import CopyCode from '../components/CopyCode.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  author?: string;
  tags?: string[];
  categories?: string[];
  readingTime: string;
  headings: { depth: number; slug: string; text: string }[];
  updated?: Date;
}

const { title, date, description, author, tags = [], readingTime, headings, updated } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updated?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <div class="post-layout container">
    <article class="post-content">
      <header class="post-header">
        <div class="post-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {
            formattedUpdated && (
              <>
                <span class="dot">&middot;</span>
                <span>Updated {formattedUpdated}</span>
              </>
            )
          }
          <span class="dot">&middot;</span>
          <span>{readingTime}</span>
          {
            author && (
              <>
                <span class="dot">&middot;</span>
                <span>{author}</span>
              </>
            )
          }
        </div>
        <h1>{title}</h1>
        {
          tags.length > 0 && (
            <div class="post-tags">
              {tags.map((tag) => (
                <a href={`/tags/${tag}`} class="tag-pill">
                  {tag}
                </a>
              ))}
            </div>
          )
        }
      </header>

      <div class="prose">
        <slot />
      </div>

      <ShareButtons title={title} />
    </article>

    <TableOfContents headings={headings} />
  </div>

  <CopyCode />

  <style>
    .post-layout {
      display: grid;
      grid-template-columns: minmax(0, var(--content-width)) 1fr;
      gap: 3rem;
      padding-top: 3rem;
      padding-bottom: 3rem;
    }

    .post-content {
      min-width: 0;
    }

    @media (max-width: 1023px) {
      .post-layout {
        grid-template-columns: 1fr;
      }
    }

    .post-header {
      margin-bottom: 2.5rem;
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.8125rem;
      color: var(--color-text-tertiary);
      margin-bottom: 0.75rem;
      flex-wrap: wrap;
    }

    .dot {
      color: var(--color-border);
    }

    .post-header h1 {
      font-size: 2.25rem;
      font-weight: 700;
      letter-spacing: -0.025em;
      line-height: 1.2;
      margin-bottom: 0.75rem;
    }

    @media (max-width: 640px) {
      .post-header h1 {
        font-size: 1.75rem;
      }
    }

    .post-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
    }

    /* ===== Prose ===== */
    .prose {
      line-height: 1.8;
      font-size: 1.0625rem;
      overflow-wrap: break-word;
      min-width: 0;
    }

    .prose :global(h2) {
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
      font-size: 1.5rem;
    }

    .prose :global(h3) {
      margin-top: 2rem;
      margin-bottom: 0.5rem;
      font-size: 1.25rem;
    }

    .prose :global(h4) {
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .prose :global(p) {
      margin-bottom: 1.25rem;
    }

    .prose :global(ul),
    .prose :global(ol) {
      margin-bottom: 1.25rem;
      padding-left: 1.5rem;
    }

    .prose :global(li) {
      margin-bottom: 0.25rem;
    }

    .prose :global(blockquote) {
      border-left: 3px solid var(--color-accent);
      padding: 0.5rem 1rem;
      margin: 1.5rem 0;
      color: var(--color-text-secondary);
      background: var(--color-bg-secondary);
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    }

    .prose :global(blockquote p:last-child) {
      margin-bottom: 0;
    }

    .prose :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      font-size: 0.9375rem;
    }

    .prose :global(th),
    .prose :global(td) {
      border: 1px solid var(--color-border-light);
      padding: 0.5rem 0.75rem;
      text-align: left;
    }

    .prose :global(th) {
      background: var(--color-bg-secondary);
      font-weight: 600;
    }

    .prose :global(hr) {
      border: none;
      border-top: 1px solid var(--color-border-light);
      margin: 2.5rem 0;
    }

    .prose :global(img) {
      border-radius: var(--radius);
      margin: 1.5rem 0;
    }

    .prose :global(mark) {
      background: var(--color-selection);
      padding: 0.1em 0.2em;
      border-radius: 0.2em;
    }

    .prose :global(kbd) {
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 0.25rem;
      padding: 0.1em 0.4em;
      font-size: 0.85em;
      font-family: inherit;
      box-shadow: 0 1px 0 var(--color-border);
    }
  </style>
</BaseLayout>
