---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/Banner.astro';
import Module from '../components/Module.astro';
import PostCard from '../components/PostCard.astro';
import Prompt from '../components/Prompt.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../utils/reading-time';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const recent = posts.slice(0, 6);
const totalPosts = posts.length;
---

<BaseLayout title="Home">
  <Banner
    command="cat /"
    status={{
      tag: 'ok',
      label: '[ OK ]',
      text: `mounting filesystem · ${totalPosts} posts loaded`,
    }}
  />

  <p class="hero-eyebrow">welcome</p>
  <h1 class="hero">aj's blog</h1>
  <p class="hero-sub">
    A personal blog focused on software, technology, and the cloud. Sharing what I'm working with at
    home — what broke, what stayed up, and what I learned getting it there.
  </p>
  <p class="hero-cta"><a href="/posts/">browse all posts</a></p>

  <Module name="recent" />
  <p class="log">
    <span class="tag-info">[INFO]</span>
    {recent.length} most recent ·
    <span style="color: var(--fg-faint)">sorted by date desc</span>
  </p>

  {
    recent.map((post) => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        description={post.data.description}
        tags={post.data.tags}
        categories={post.data.categories}
        image={post.data.image}
        readingTime={getReadingTime(post.body || '')}
        href={`/posts/${post.id}/`}
        draft={post.data.draft}
      />
    ))
  }

  <p class="log" style="margin-top: 1.5rem">
    <span class="tag-note">[NOTE]</span>
    <a href="/posts/">view all {totalPosts} posts</a> · feed at <a href="/rss.xml">/rss.xml</a>
  </p>

  <Prompt />
</BaseLayout>
