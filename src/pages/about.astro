---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/Banner.astro';
import Module from '../components/Module.astro';
import Prompt from '../components/Prompt.astro';

interface Project {
  title: string;
  description: string;
  tags: string[];
  url: string;
}

const projects: Project[] = [
  {
    title: "AJ's Blog",
    description:
      'This site - a static blog built with Astro, served by AWS Amplify, deployed via GitLab CI.',
    tags: ['astro', 'typescript', 'gitlab-ci'],
    url: 'https://gitlab.com/acaylor/ajs-blog',
  },
  {
    title: 'Homelab Infrastructure',
    description:
      'Self-hosted services on Kubernetes across Proxmox and Raspberry Pis with automated deployments and monitoring.',
    tags: ['kubernetes', 'proxmox', 'argocd'],
    url: '/posts/homelab-2025-plans/',
  },
  {
    title: 'Home Assistant Poller',
    description: 'A Go service that polls Home Assistant and stores sensor data in a database.',
    tags: ['go', 'home-assistant', 'timescaledb', 'grafana'],
    url: 'https://github.com/acaylor/hass-poller',
  },
];

interface HardwareRow {
  node: string;
  device: string;
}

const hardware: HardwareRow[] = [
  { node: 'net0', device: 'UniFi UDM Pro · cameras · switches' },
  { node: 'nas0', device: 'Synology NAS · 12 TB' },
  { node: 'nas1', device: 'backup NAS · 4 TB' },
  { node: 'pve0..3', device: 'Proxmox cluster · 4 nodes' },
  { node: 'pi0..4', device: 'Raspberry Pi fleet · 5 units' },
  { node: 'gpu0', device: 'Linux server · Nvidia GPU' },
  { node: 'mac0', device: 'M4 Mac mini' },
];
---

<BaseLayout title="About">
  <Banner
    command="cat /about"
    status={{
      tag: 'ok',
      label: '[ OK ]',
      text: 'loading runtime: astro · nginx · static',
    }}
  />

  <h1 class="title">whoami</h1>
  <p class="title-sub">acaylor &middot; senior platform engineer</p>

  <Module name="intro" ts="0.012" />
  <p class="log">
    This site is a personal blog focused on software, technology, and the cloud. The main purpose is
    to share what I'm running at home and what I learned getting it to stay up.
  </p>
  <div class="figure avatar">
    <img src="/images/whoami/whoami.png" alt="Profile photo" />
    <div class="figcap">
      <b>fig. 0 — operator portrait</b>github.com/acaylor &middot; gitlab.com/acaylor
    </div>
  </div>

  <Module name="author" ts="0.024" />
  <p class="log">
    <span class="tag-info">[INFO]</span> Currently a Senior Platform Engineer. I enjoy working with the
    latest technology in my homelab and writing posts that survive past the first edit.
  </p>

  <Module name="contact" ts="0.041" id="contact" />
  <p class="log">
    <span class="tag-warn">[WARN]</span> comments are disabled. The previous platform added ads and there
    was no engagement. write directly if you have something to say. I appreciate folks who have reached
    out over the years.
  </p>
  <dl class="channels">
    <div class="channel">
      <dt class="k">email</dt>
      <dd class="v"><a href="mailto:ayyyj@icloud.com">ayyyj@icloud.com</a></dd>
    </div>
    <div class="channel">
      <dt class="k">discord</dt>
      <dd class="v">.ayyj</dd>
    </div>
    <div class="channel">
      <dt class="k">github</dt>
      <dd class="v">
        <a href="https://github.com/acaylor" target="_blank" rel="noopener noreferrer">acaylor</a>
      </dd>
    </div>
    <div class="channel">
      <dt class="k">gitlab</dt>
      <dd class="v">
        <a href="https://gitlab.com/acaylor" target="_blank" rel="noopener noreferrer">acaylor</a>
      </dd>
    </div>
  </dl>

  <Module name="history" ts="0.082" />
  <p class="log">
    The lab began with the first-model Raspberry Pi while I was in school. I wrote a version of
    Snake in Java, compiled it to a jar, dropped it on the Pi behind an Apache web server, and used
    a proxy so I could pull it down from anywhere. That hooked me on networking and self-hosting.
  </p>
  <p class="log">
    I set up an Ubuntu NAS with SMB and moved everything off the Pi. My coursework was Java until a
    final web-dev class that ran on ASP.NET. My capstone project was a meal-prep app with a recipe
    database which was the first time I used <code>git</code> to collaborate.
  </p>
  <p class="log">
    First job was Windows AD plus a Linux HPC fleet. I ran a Dell PowerEdge R510 at home with ESXi
    and Windows VMs for AD lab work. Every job after has been Linux-shaped. Around 2018 I moved the
    lab to Proxmox and TrueNAS. Later jobs centered on Kubernetes, so the lab followed with Ubuntu
    VMs running k8s clusters. Now I am running a mix of Raspberry Pis and Proxmox VMs with k3s.
  </p>

  <Module name="hardware" ts="0.142" />
  <p class="log"><span class="tag-info">[INFO]</span> scanning hardware ...</p>
  <table class="proc" aria-label="Hardware inventory">
    <thead>
      <tr>
        <th scope="col">node</th>
        <th scope="col">device</th>
        <th scope="col">status</th>
      </tr>
    </thead>
    <tbody>
      {
        hardware.map((row) => (
          <tr>
            <td>{row.node}</td>
            <td>{row.device}</td>
            <td>
              <span class="tag-ok">ok</span>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
  <p class="log">
    <span class="tag-note">[NOTE]</span> power draw offset by solar &middot; wireguard for remote &middot;
    password manager for secrets
  </p>

  <Module name="projects" ts="0.201" />
  <p class="log">
    <span class="tag-info">[INFO]</span> active units &middot;
    <span style="color: var(--fg-faint)">
      use <a href="/posts/">posts</a> for more
    </span>
  </p>
  {
    projects.map((project) => {
      const isExternal = project.url.startsWith('http');
      return (
        <div class="unit">
          <div class="head">
            <span class="dot" aria-hidden="true">
              ●
            </span>
            <span class="name">
              <a
                href={project.url}
                {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {project.title}
              </a>
            </span>
          </div>
          <div class="desc">{project.description}</div>
          {project.tags.length > 0 && (
            <div class="tags">
              <span class="label">tags</span>
              {project.tags.map((tag) => (
                <span class="tag-link">{tag}</span>
              ))}
            </div>
          )}
        </div>
      );
    })
  }

  <Prompt />
</BaseLayout>
