---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Banner from '../../../components/Banner.astro';
import Module from '../../../components/Module.astro';
import PostEntry from '../../../components/PostEntry.astro';
import Pagination from '../../../components/Pagination.astro';
import Prompt from '../../../components/Prompt.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../../utils/reading-time';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = new Set<string>();
  posts.forEach((post) => post.data.categories?.forEach((cat) => categories.add(cat)));

  return [...categories].flatMap((category) => {
    const filtered = posts
      .filter((post) => post.data.categories?.includes(category))
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
    return paginate(filtered, { params: { category }, pageSize: 12 });
  });
}) satisfies GetStaticPaths;

const { category } = Astro.params;
const { page } = Astro.props;
const moduleName = `page_${String(page.currentPage).padStart(3, '0')}`;
const pageLabel = `page ${page.currentPage}/${page.lastPage}`;
const basePath = `/categories/${category}`;
---

<BaseLayout
  title={page.currentPage > 1 ? `${category} - Page ${page.currentPage}` : String(category)}
>
  <Banner
    command={`ls -lah /categories/${category}/`}
    status={{
      tag: 'info',
      label: '[INFO]',
      text: `${page.total} entries · ${pageLabel} · sorted by date desc`,
    }}
  />

  <h1 class="title">category: {category}</h1>
  <p class="title-sub">
    <a href="/categories/">&larr; all categories</a>
  </p>

  <Module name={moduleName} />

  {
    page.data.map((post) => (
      <PostEntry
        title={post.data.title}
        date={post.data.date}
        href={`/posts/${post.id}/`}
        readingTime={getReadingTime(post.body || '')}
        tags={post.data.tags}
      />
    ))
  }

  <Pagination currentPage={page.currentPage} lastPage={page.lastPage} basePath={basePath} />

  <Prompt />
</BaseLayout>
