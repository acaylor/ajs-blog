---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Banner from '../../components/Banner.astro';
import Prompt from '../../components/Prompt.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);

const counts = new Map<string, number>();
for (const post of posts) {
  for (const cat of post.data.categories ?? []) {
    counts.set(cat, (counts.get(cat) ?? 0) + 1);
  }
}

const categories = [...counts.entries()]
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));

const totalUses = categories.reduce((sum, c) => sum + c.count, 0);
const maxCount = categories[0]?.count ?? 1;
---

<BaseLayout title="Categories">
  <Banner
    command="ls -lah /categories"
    status={{
      tag: 'info',
      label: '[INFO]',
      text: `${categories.length} categories · sorted by count desc`,
    }}
  />

  <h1 class="title">categories</h1>
  <p class="title-sub">{categories.length} categories across {posts.length} posts</p>

  <table class="stat" aria-label="Category frequency">
    <thead>
      <tr>
        <th scope="col">category</th>
        <th scope="col" class="bar">usage</th>
        <th scope="col">count</th>
        <th scope="col">%</th>
      </tr>
    </thead>
    <tbody>
      {
        categories.map(({ name, count }) => {
          const pct = (count / totalUses) * 100;
          const barPct = (count / maxCount) * 100;
          return (
            <tr>
              <td class="name">
                <a href={`/categories/${name}/`}>{name}</a>
              </td>
              <td class="bar">
                <span class="bar-track" aria-hidden="true">
                  <span class="bar-fill" style={`width: ${barPct.toFixed(1)}%`} />
                </span>
              </td>
              <td class="count">{count}</td>
              <td class="pct">{pct.toFixed(1)}%</td>
            </tr>
          );
        })
      }
    </tbody>
  </table>

  <Prompt />
</BaseLayout>
