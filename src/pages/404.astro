---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/Banner.astro';
import Prompt from '../components/Prompt.astro';
---

<BaseLayout title="404">
  <Banner
    showPreamble={false}
    status={{
      tag: 'err',
      label: '[FAIL]',
      text: 'segfault at 0x00000194 ip 0x00000404 error 4 in route.so',
    }}
  />

  <h1 class="title">404</h1>
  <p class="title-sub">Kernel panic — not syncing: attempted to read a page that does not exist</p>

  <pre
    class="panic"
    aria-hidden="true">Call Trace:
 &lt;TASK&gt;
 resolve_route+0x194/0x404 [aj_blog]
 render_page+0x0ff/0xdead [astro]
 do_request+0x042/0x1337
 entry_HTTP_GET+0x00/0x80
 &lt;/TASK&gt;
---[ end trace 0000000000000404 ]---</pre>

  <p class="log">
    <span class="tag-note">[NOTE]</span> the route may have been moved or removed. try one of:
  </p>
  <ul class="not-found-links">
    <li><a href="/">/</a> &mdash; home</li>
    <li><a href="/posts/">/posts</a> &mdash; the full archive</li>
    <li><a href="/tags/">/tags</a> &mdash; topic index</li>
    <li><a href="/categories/">/categories</a> &mdash; category index</li>
  </ul>

  <p class="log not-found-cd">
    <a href="/">aj@blog:~$ cd /</a>
  </p>

  <Prompt />
</BaseLayout>

<style>
  .panic {
    margin: 1rem 0 1.5rem;
    font-size: 12px;
    line-height: 1.6;
    color: var(--fg-faint);
    max-width: 68ch;
  }
  .not-found-links {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 1rem;
    font-size: 13px;
    color: var(--fg-soft);
  }
  .not-found-links li {
    padding: 0.15rem 0;
  }
  .not-found-links a {
    text-decoration: none;
  }
  .not-found-links a:hover {
    text-decoration: underline;
  }
  .not-found-cd {
    margin-top: 1.5rem;
  }
  .not-found-cd a {
    text-decoration: none;
    color: var(--ok);
  }
  .not-found-cd a:hover {
    color: var(--amber);
  }
</style>
